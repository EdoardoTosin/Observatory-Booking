# ─── Database ─────────────────────────────────────────────────────────────────
# SQLAlchemy connection URL. Defaults to a local SQLite file.
# For PostgreSQL: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///observatory_booking.db

# ─── Cryptographic Keys ───────────────────────────────────────────────────────
# Leave blank - if absent, a secure random value is generated on first start
# and written back to this file automatically.
SECRET_KEY=
AES_SECRET_KEY=
AES_HMAC_KEY=
AES_IV=

# ─── Superadmin Bootstrap ─────────────────────────────────────────────────────
# Used only on first run to create the superadmin account.
# Leave DEFAULT_ADMIN_PASSWORD blank - a secure random password is generated,
# printed once to stdout, and must be changed immediately after first login.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=

# ─── Runtime ──────────────────────────────────────────────────────────────────
# ENV controls SQLAlchemy echo (set to "development" to enable SQL logging).
ENV=production
DEBUG_MODE=False
HOST=127.0.0.1
PORT=5000

# ─── Session Cookie ───────────────────────────────────────────────────────────
# SESSION_COOKIE_SECURE must be True in production (requires HTTPS).
# Set to False only for local HTTP development.
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Strict
# Leave blank to use Flask's default (current host).
SESSION_COOKIE_DOMAIN=

# ─── Security ─────────────────────────────────────────────────────────────────
WTF_CSRF_ENABLED=True

# ─── Logging ──────────────────────────────────────────────────────────────────
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOGGING_LEVEL=INFO
